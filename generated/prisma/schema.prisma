generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ALUNO
  PROFESSOR
  ADMIN
}

enum UserStatus {
  PENDENTE
  ATIVO
  INATIVO
  TRANSFERIDO
}

model User {
  id               String     @id @default(uuid())
  nome             String
  email            String?    @unique
  telefone         String?
  numeroUtilizador String?    @unique
  senhaHash        String
  role             Role
  status           UserStatus @default(ATIVO)
  avatar           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  admin     Admin?
  professor Professor?
  aluno     Aluno?

  @@map("users")
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  instituicoes  Instituicao[]
  anosLectivos  AnoLectivo[]
  configuracoes Configuracao[]

  @@map("admins")
}

model Professor {
  id       String  @id @default(uuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id])
  cargo    String
  contacto String?

  disciplinas ProfessorDisciplina[]
  materiais   MaterialDidatico[]
  avisos      Aviso[]
  horarios    HorarioAula[]

  @@map("professores")
}

model Aluno {
  id                        String    @id @default(uuid())
  userId                    String    @unique
  user                      User      @relation(fields: [userId], references: [id])
  dataNascimento            DateTime
  tipoIdentificacao         String
  numeroIdentificacao       String
  numeroProcesso            String    @unique
  ultimaClasseFrequentada   String?
  turmaId                   String?
  turma                     Turma?    @relation(fields: [turmaId], references: [id])
  curso                     String?
  classe                    String?
  turno                     String?
  genero                    String?
  estadoCivil               String?
  nomePai                   String?
  nomeMae                   String?
  naturalidade              String?
  provincia                 String?
  municipio                 String?
  comuna                    String?
  encarregadoNome           String?
  encarregadoParentesco     String?
  encarregadoGenero         String?
  encarregadoDataNascimento DateTime?
  encarregadoTelefone       String?
  encarregadoEmail          String?

  resultados    Resultado[]
  faltas        Falta[]
  convocatorias Convocatoria[]

  @@map("alunos")
}

model Curso {
  id        String  @id @default(uuid())
  nome      String
  sigla     String
  descricao String?
  ativo     Boolean @default(true)

  turmas      Turma[]
  disciplinas Disciplina[]

  @@map("cursos")
}

model Turma {
  id         String   @id @default(uuid())
  nome       String
  cursoId    String
  classe     String
  vagas      Int
  turno      String
  anoLectivo String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  curso       Curso                 @relation(fields: [cursoId], references: [id])
  alunos      Aluno[]
  professores ProfessorDisciplina[]
  exames      Exame[]
  horarios    HorarioAula[]

  @@unique([nome, cursoId])
  @@map("turmas")
}

model Disciplina {
  id           String   @id @default(uuid())
  nome         String
  sigla        String
  cursoId      String
  classe       String
  cargaHoraria Int
  cor          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  curso       Curso                 @relation(fields: [cursoId], references: [id])
  professores ProfessorDisciplina[]
  exames      Exame[]
  materiais   MaterialDidatico[]
  avisos      Aviso[]
  faltas      Falta[]
  horarios    HorarioAula[]

  @@unique([nome, cursoId, classe])
  @@map("disciplinas")
}

model ProfessorDisciplina {
  professorId  String
  disciplinaId String
  turmaId      String

  professor  Professor  @relation(fields: [professorId], references: [id])
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  turma      Turma      @relation(fields: [turmaId], references: [id])

  @@id([professorId, disciplinaId, turmaId])
  @@map("professor_disciplinas")
}

model Instituicao {
  id        String   @id @default(uuid())
  nome      String
  sigla     String
  endereco  String?
  telefone  String?
  email     String?
  website   String?
  diretor   String?
  logotipo  String?
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("instituicoes")
}

model AnoLectivo {
  id         String   @id @default(uuid())
  ano        String   @unique
  dataInicio DateTime
  dataFim    DateTime
  activo     Boolean  @default(false)
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("anos_lectivos")
}

model Configuracao {
  id        String   @id @default(uuid())
  chave     String   @unique
  valor     String
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  updatedAt DateTime @updatedAt

  @@map("configuracoes")
}

model Trimestre {
  id         String   @id @default(uuid())
  nome       String
  anoLectivo String
  dataInicio DateTime
  dataFim    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([nome, anoLectivo])
  @@map("trimestres")
}

model ParametroAvaliacao {
  id        String   @id @default(uuid())
  nome      String
  sigla     String   @unique
  descricao String?
  peso      Int
  ordem     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("parametros_avaliacao")
}

enum ExameEstado {
  AGENDADO
  REALIZADO
  CANCELADO
}

model Exame {
  id           String      @id @default(uuid())
  disciplinaId String
  turmaId      String
  data         DateTime
  hora         String
  sala         String
  tipo         String
  trimestre    String
  estado       ExameEstado @default(AGENDADO)
  observacoes  String?
  curso        String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  disciplina Disciplina  @relation(fields: [disciplinaId], references: [id])
  turma      Turma       @relation(fields: [turmaId], references: [id])
  resultados Resultado[]

  @@map("exames")
}

model Resultado {
  id        String   @id @default(uuid())
  exameId   String
  alunoId   String
  nota      Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exame Exame @relation(fields: [exameId], references: [id])
  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@unique([exameId, alunoId])
  @@map("resultados")
}

model EpocaExame {
  id         String   @id @default(uuid())
  label      String
  trimestre  String
  dataInicio DateTime
  dataFim    DateTime
  tipo       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("epocas_exame")
}

enum LogTipo {
  LOGIN
  LOGOUT
  CRIAR
  ACTUALIZAR
  REMOVER
  TRANSFERIR
  NOTA
  CONFIG
  EXAME
  AVISO
}

model AuditoriaLog {
  id           String   @id @default(uuid())
  tipo         LogTipo
  descricao    String
  utilizador   String
  utilizadorId String?
  role         String
  entidade     String?
  entidadeId   String?
  data         DateTime @default(now())

  @@map("auditoria_logs")
}

model Cargo {
  id        String   @id @default(uuid())
  nome      String   @unique
  descricao String?
  tipo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cargos")
}

model Permissao {
  id        String   @id @default(uuid())
  modulo    String   @unique
  descricao String?
  admin     Boolean  @default(true)
  professor Boolean  @default(false)
  aluno     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permissoes")
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
}

model MaterialDidatico {
  id           String   @id @default(uuid())
  titulo       String
  descricao    String?
  tipo         String   @default("pdf")
  url          String?
  ficheiro     String?
  tamanho      Int?
  visivel      Boolean  @default(true)
  disciplinaId String
  professorId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  professor  Professor  @relation(fields: [professorId], references: [id])

  @@map("materiais_didaticos")
}

model Aviso {
  id           String   @id @default(uuid())
  texto        String
  disciplinaId String
  autor        String
  professorId  String
  createdAt    DateTime @default(now())

  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  professor  Professor  @relation(fields: [professorId], references: [id])

  @@map("avisos")
}

model Falta {
  id           String   @id @default(uuid())
  alunoId      String
  disciplinaId String
  data         DateTime
  justificada  Boolean  @default(false)
  justificacao String?
  createdAt    DateTime @default(now())

  aluno      Aluno      @relation(fields: [alunoId], references: [id])
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])

  @@unique([alunoId, disciplinaId, data])
  @@map("faltas")
}

model HorarioAula {
  id           String    @id @default(uuid())
  dia          DiaSemana
  horaInicio   String
  horaFim      String
  disciplinaId String
  professorId  String
  turmaId      String
  sala         String?
  createdAt    DateTime  @default(now())

  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  professor  Professor  @relation(fields: [professorId], references: [id])
  turma      Turma      @relation(fields: [turmaId], references: [id])

  @@map("horario_aulas")
}

model Convocatoria {
  id             String   @id @default(uuid())
  alunoId        String
  trimestre      String
  dataEmissao    DateTime
  dataRealizacao DateTime
  hora           String
  sala           String
  agenda         String[]
  createdAt      DateTime @default(now())

  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@map("convocatorias")
}

model Informacao {
  id             String   @id @default(uuid())
  titulo         String
  descricao      String?
  conteudo       String
  dataPublicacao DateTime @default(now())
  imagemUrl      String?
  link           String?
  hasIcon        Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("informacoes")
}

model AdminUtilizador {
  id           String    @id @default(uuid())
  nome         String
  email        String    @unique
  username     String    @unique
  cargo        String?
  role         String    @default("admin")
  ativo        Boolean   @default(true)
  senhaHash    String
  ultimoAcesso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_utilizadores")
}
